{
  "name": "aladinn-his-assistant",
  "version": "2.2.2",
  "description": "Tiện ích mở rộng AI (Giọng nói & Quét Dữ liệu) cho hệ thống VNPT HIS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "release": "node scripts/release.js",
    "package:cws": "node scripts/package-cws.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "analyze": "gitnexus analyze",
    "sync:drugs": "node scripts/sync-drugs.cjs",
    "process:drugs": "npm run sync:drugs && node scripts/ai-pharmacist-pipeline.cjs && npm run build",
    "process:nhic": "node scripts/pipeline_nhic.cjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.0",
    "gitnexus": "^1.6.3",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
