{
    "manifest_version": 3,
    "name": "Aladinn - VNPT HIS AI Assistant",
    "version": "1.1.9",
    "description": "Tiện ích mở rộng siêu cấp vũ trụ dành cho hệ thống VNPT HIS: Giọng nói AI, Quét dữ liệu, Ký số tự động",
    "author": "Huỳnh Trung Anh",
    "permissions": [
        "activeTab",
        "alarms",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://*.vncare.vn/*",
        "https://generativelanguage.googleapis.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icons/icon16.png",
            "32": "assets/icons/icon32.png",
            "48": "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        },
        "default_title": "Aladinn — VNPT HIS Assistant v1.1.9"
    },
    "icons": {
        "16": "assets/icons/icon16.png",
        "32": "assets/icons/icon32.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "commands": {
        "quick-filter": {
            "suggested_key": {
                "default": "Ctrl+Shift+F",
                "mac": "Command+Shift+F"
            },
            "description": "Lọc hồ sơ của tôi"
        },
        "start-signing": {
            "suggested_key": {
                "default": "Ctrl+Shift+S",
                "mac": "Command+Shift+S"
            },
            "description": "Bắt đầu ký số"
        },
        "next-patient": {
            "suggested_key": {
                "default": "Ctrl+Shift+N",
                "mac": "Command+Shift+N"
            },
            "description": "Bệnh nhân tiếp theo"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.vncare.vn/*"
            ],
            "js": [
                "lib/jquery.min.js",
                "content/main.js"
            ],
            "run_at": "document_end",
            "all_frames": false
        },
        {
            "matches": [
                "https://*.vncare.vn/*"
            ],
            "js": [
                "content/scanner/history-iframe-helper.js",
                "content/scanner/nutrition-iframe-helper.js",
                "content/scanner/emergency-iframe-helper.js",
                "content/scanner/hoichan-iframe-helper.js",
                "content/scanner/chuyenvien-iframe-helper.js",
                "content/cds/cds-iframe-helper.js"
            ],
            "run_at": "document_end",
            "all_frames": true
        },
        {
            "matches": [
                "https://*.vncare.vn/*"
            ],
            "js": [
                "content/sign/auto-click-helper.js"
            ],
            "run_at": "document_end",
            "all_frames": true
        }
    ],
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "options_ui": {
        "page": "options/options.html",
        "open_in_tab": true
    },
    "web_accessible_resources": [
        {
            "resources": [
                "injected/*.js",
                "content/scanner/*-iframe-helper.js",
                "styles/aladinn-scanner.css",
                "styles/aladinn-voice.css",
                "assets/icons/*"
            ],
            "matches": [
                "https://*.vncare.vn/*"
            ],
            "use_dynamic_url": true
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com"
    }
}