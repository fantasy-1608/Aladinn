{
    "env": {
        "browser": true,
        "es2021": true,
        "webextensions": true
    },
    "extends": [
        "eslint:recommended"
    ],
    "parserOptions": {
        "ecmaVersion": 12,
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
        "no-empty": ["warn", { "allowEmptyCatch": false }],
        "no-console": "off",
        "semi": ["warn", "always"],
        "quotes": ["warn", "single", { "avoidEscape": true }]
    },
    "globals": {
        "HIS": "readonly",
        "VNPTStore": "readonly",
        "VNPTConfig": "readonly",
        "VNPTSettings": "readonly",
        "Aladinn": "readonly",
        "jQuery": "readonly",
        "$": "readonly"
    }
}
